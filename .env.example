# MongoDB — credentials used by docker-compose.yml to initialise the MongoDB container
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=

# Database name — used by docker-compose.yml to build the container MONGO_URI
DB_NAME=

# Server port
PORT=

# Worker concurrency — number of parallel jobs for the import worker
IMPORT_WORKER_CONCURRENCY=

# Node environment
NODE_ENV=production