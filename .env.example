# MongoDB — credentials used by docker-compose.yml to initialise the MongoDB container
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=

# Database name — used by docker-compose.yml to build the container MONGO_URI
DB_NAME=

# Server port
PORT=

# Worker concurrency — number of parallel jobs for the import worker
# WARNING: Higher values increase throughput but also increase memory/CPU usage and database connections
# Recommended to keep this at 5 or below for typical development machines and small datasets. Adjust as needed for production environments.
IMPORT_WORKER_CONCURRENCY=5

# Node environment
NODE_ENV=production